# Copy to docker/.env and fill in secrets (never commit docker/.env).

# Images (local build defaults; CI uses ghcr.io/<owner>/bobaclaw:latest)
BOBACLAW_IMAGE=bobaclaw/bobaclaw:latest
BOBACLAW_SANDBOX_IMAGE=bobaclaw/sandbox:latest
OBSCURA_MCP_IMAGE=h4ckf0r0day/obscura

# Gateway port on the host
BOBACLAW_GATEWAY_PORT=18790

# Pull sandbox + obscura on container start (1 = yes)
BOBACLAW_PULL_IMAGES=1

# Provider + Telegram (required for gateway)
OPENAI_API_KEY=
TELEGRAM_BOT_TOKEN=

# Optional Telegram Bot API proxy (HTTP or SOCKS5)
# TELEGRAM_PROXY=http://192.168.88.220:11882

# Logging
# RUST_LOG=bobaclaw=info
