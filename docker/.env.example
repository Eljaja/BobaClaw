# Optional — NOT required on the server.
# Production secrets live in /opt/bobaclaw/data/config.yaml (bind-mounted to /data).
#
# Use this file only for local overrides: image tags, logging, compose port.
#   cp docker/.env.example docker/.env

# Images (CI sets these on deploy; override for local builds)
BOBACLAW_IMAGE=bobaclaw/bobaclaw:latest
BOBACLAW_SANDBOX_IMAGE=bobaclaw/sandbox:latest
OBSCURA_MCP_IMAGE=h4ckf0r0day/obscura

# Gateway port on the host
BOBACLAW_GATEWAY_PORT=18790

# Pull sandbox + obscura on container start (1 = yes)
BOBACLAW_PULL_IMAGES=1

# Logging
# RUST_LOG=bobaclaw=info
