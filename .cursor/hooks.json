{
  "version": 1,
  "hooks": {
    "afterFileEdit": [
      {
        "command": "wsl bash .cursor/hooks/rust-fmt-after-edit.sh",
        "timeout": 120
      }
    ],
    "stop": [
      {
        "command": "wsl bash .cursor/hooks/rust-fmt-check-stop.sh",
        "timeout": 120,
        "loop_limit": 3
      }
    ]
  }
}
